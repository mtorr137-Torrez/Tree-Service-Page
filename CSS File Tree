body {
  font-family: Arial;
  margin: 0;
}

header {
  background-color: green;
  color: white;
  text-align: center;
  padding: 20px;
}

nav {
  background-color: lightgray;
  text-align: center;
  padding: 10px;
}

nav a {
  margin: 10px;
  text-decoration: none;
}

main {
  padding: 20px;
}

table {
  width: 100%;
  border-collapse: collapse;
}

th, td {
  border: 1px solid black;
  padding: 10px;
}

th {
  background-color: green;
  color: white;
}

form {
  display: flex;
  flex-direction: column;
  width: 300px;
}

input, textarea {
  margin-bottom: 10px;
  padding: 5px;
}

footer {
  text-align: center;
  padding: 10px;
  background-color: lightgray;
}
